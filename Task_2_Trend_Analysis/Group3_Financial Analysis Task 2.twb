        <calculation class='tableau' formula='[COGSTot]/TradeAcctPbleAccrualsST' />
      </column>
      <column caption='Operating profit margin' datatype='real' name='[Calculation_0914262324785153]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[EBIT]/[TotRevenue]' />
      </column>
      <column caption='Debt to asset ratio' datatype='real' name='[Calculation_0914262325481474]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[TotLiab]/ [TotAssets]' />
      </column>
      <column caption='Inventory Turnover' datatype='real' name='[Calculation_1703711315365890]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[COGSTot]/[InvntTot_avg]' />
      </column>
      <column caption='Total asset turnover' datatype='real' name='[Calculation_1703711318654979]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='TotRevenue/[TotAssets_avg]' />
      </column>
      <column caption='Net profit margin' datatype='real' name='[Calculation_2180349764739072]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(NetIncAfterTax/TotRevenue)' />
      </column>
      <column caption='Return on Assets' datatype='real' name='[Calculation_2180349766930433]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(NetIncAfterTax/TotAssets_avg)' />
      </column>
      <column caption='Current ratio' datatype='real' name='[Calculation_2180349768110083]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='TotCurrAssets/TotCurrLiab' />
      </column>
      <column caption='Quick ratio' datatype='real' name='[Calculation_2180349769613316]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(TotCurrAssets-InvntTot )/TotCurrLiab' />
      </column>
      <column caption='Interest coverage ratio' datatype='real' name='[Calculation_2180349770272773]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='EBIT/IntrExpn' />
      </column>
      <column caption='Equity ratio' datatype='real' name='[Calculation_2180349770776582]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='TotShHoldEq/TotAssets' />
      </column>
      <column caption='Operating profit' datatype='integer' name='[Calculation_2180349775335432]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[TotRevenue]-[COGSTot]-([OpExpnTot] - [COGSTot])' />
      </column>
